/* ===== RESET & BASE ===== */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --cream: #f5f0e8;
  --dark: #1a1714;
  --forest: #2c4a2e;
  --gold: #b8986a;
  --muted: #7a6f5e;
  --border: #ddd5c4;
  --white: #fffdf8;
  --error: #8b2020;
  --success: #1e4d2b;
}

html { scroll-behavior: smooth; }

body {
  font-family: 'Jost', sans-serif;
  background: var(--white);
  color: var(--dark);
  font-size: 15px;
  line-height: 1.6;
  font-weight: 300;
}

/* ===== NAVBAR ===== */
.navbar {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.2rem 3rem;
  background: rgba(255,253,248,0.92);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid var(--border);
}

.nav-logo {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.5rem;
  font-weight: 600;
  letter-spacing: 0.05em;
  color: var(--forest);
}

.nav-links a {
  text-decoration: none;
  color: var(--muted);
  font-size: 0.8rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-left: 2rem;
  transition: color 0.2s;
}
.nav-links a:hover { color: var(--forest); }

/* ===== HERO ===== */
.hero {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  padding: 6rem 2rem 4rem;
}

.hero-bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse at 30% 60%, rgba(44,74,46,0.12) 0%, transparent 60%),
    radial-gradient(ellipse at 70% 30%, rgba(184,152,106,0.1) 0%, transparent 60%),
    linear-gradient(160deg, #f5f0e8 0%, #ede5d4 100%);
}

.hero-content {
  position: relative;
  z-index: 1;
  text-align: center;
  max-width: 700px;
}

.hero-tagline {
  font-size: 0.75rem;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 1.2rem;
}

.hero-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(3rem, 8vw, 5.5rem);
  font-weight: 300;
  line-height: 1.05;
  color: var(--dark);
  margin-bottom: 1.5rem;
}

.hero-title em {
  font-style: italic;
  color: var(--forest);
}

.hero-sub {
  color: var(--muted);
  font-size: 1rem;
  max-width: 480px;
  margin: 0 auto 2.5rem;
}

.hero-scroll-hint {
  position: absolute;
  bottom: 2rem;
  left: 50%;
  transform: translateX(-50%);
  font-size: 0.7rem;
  letter-spacing: 0.15em;
  color: var(--muted);
  opacity: 0.6;
}

/* ===== BUTTONS ===== */
.btn-primary {
  display: inline-block;
  background: var(--forest);
  color: var(--cream);
  padding: 0.9rem 2.4rem;
  text-decoration: none;
  font-size: 0.78rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  border: none;
  cursor: pointer;
  transition: background 0.25s, transform 0.15s;
  font-family: 'Jost', sans-serif;
  font-weight: 400;
}
.btn-primary:hover { background: #1e361f; transform: translateY(-1px); }
.btn-primary.full-width { width: 100%; text-align: center; padding: 1.1rem; }

.btn-outline {
  display: inline-block;
  border: 1.5px solid var(--forest);
  color: var(--forest);
  padding: 0.85rem 2.2rem;
  text-decoration: none;
  font-size: 0.78rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  transition: all 0.25s;
  font-family: 'Jost', sans-serif;
  font-weight: 400;
  background: transparent;
}
.btn-outline:hover { background: var(--forest); color: var(--white); }

/* ===== FEATURES ===== */
.features-section {
  background: var(--dark);
  padding: 5rem 2rem;
}

.features-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 2rem;
  max-width: 1000px;
  margin: 0 auto;
}

.feature-card {
  padding: 2rem;
  border: 1px solid rgba(255,255,255,0.08);
  text-align: center;
}

.feat-icon { font-size: 2rem; margin-bottom: 1rem; }

.feature-card h3 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.5rem;
  font-weight: 400;
  color: var(--cream);
  margin-bottom: 0.75rem;
}

.feature-card p { color: rgba(245,240,232,0.55); font-size: 0.9rem; }

/* ===== HOURS ===== */
.hours-section {
  padding: 5rem 2rem;
  background: var(--cream);
}

.hours-inner {
  max-width: 600px;
  margin: 0 auto;
  text-align: center;
}

.hours-inner h2 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 2.5rem;
  font-weight: 300;
  margin-bottom: 2rem;
  color: var(--dark);
}

.hours-table {
  margin-bottom: 2.5rem;
}

.hours-table > div {
  display: flex;
  justify-content: space-between;
  padding: 0.75rem 0;
  border-bottom: 1px solid var(--border);
  font-size: 0.95rem;
}

.hours-table span:last-child { color: var(--forest); font-weight: 400; }

/* ===== PAGE HEADER ===== */
.page-header {
  margin-top: 80px;
  padding: 4rem 2rem 2rem;
  text-align: center;
  background: var(--cream);
  border-bottom: 1px solid var(--border);
}

.page-header h1 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 2.8rem;
  font-weight: 300;
  color: var(--dark);
  margin-bottom: 0.5rem;
}

.page-header p { color: var(--muted); }

/* ===== FORM ===== */
.form-container {
  max-width: 740px;
  margin: 3rem auto 4rem;
  padding: 0 1.5rem;
}

.form-section-label {
  font-size: 0.7rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--gold);
  margin: 2.5rem 0 1.2rem;
  padding-bottom: 0.4rem;
  border-bottom: 1px solid var(--border);
}

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.2rem;
}

@media (max-width: 560px) { .form-row { grid-template-columns: 1fr; } }

.form-group {
  display: flex;
  flex-direction: column;
  margin-bottom: 1.2rem;
}

.form-group label {
  font-size: 0.75rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 0.45rem;
}

.form-group input,
.form-group select,
.form-group textarea {
  border: 1.5px solid var(--border);
  padding: 0.75rem 1rem;
  font-family: 'Jost', sans-serif;
  font-size: 0.95rem;
  font-weight: 300;
  background: var(--white);
  color: var(--dark);
  outline: none;
  transition: border-color 0.2s;
  -webkit-appearance: none;
  border-radius: 0;
}

.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus { border-color: var(--forest); }

.form-group textarea { resize: vertical; }

/* Table grid selector */
.table-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
  gap: 0.8rem;
  margin-bottom: 0.75rem;
}

.table-card {
  cursor: pointer;
  border: 1.5px solid var(--border);
  transition: all 0.2s;
  display: block;
}

.table-card input[type="radio"] { display: none; }

.table-card-inner {
  padding: 0.9rem 0.75rem;
  text-align: center;
}

.table-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.8rem;
  font-weight: 300;
  color: var(--muted);
  line-height: 1;
  margin-bottom: 0.3rem;
}

.table-name {
  font-size: 0.78rem;
  font-weight: 500;
  color: var(--dark);
}

.table-detail {
  font-size: 0.7rem;
  color: var(--muted);
  margin-top: 0.2rem;
}

.table-card:hover { border-color: var(--forest); }
.table-card.selected { border-color: var(--forest); background: rgba(44,74,46,0.06); }
.table-card.unavailable { opacity: 0.35; cursor: not-allowed; pointer-events: none; }
.table-card.selected .table-num { color: var(--forest); }

.avail-note {
  font-size: 0.8rem;
  color: var(--muted);
  margin-top: 0.4rem;
}

.alert-error {
  background: #fef2f2;
  border: 1.5px solid #f5c6c6;
  color: var(--error);
  padding: 0.9rem 1.1rem;
  font-size: 0.9rem;
  margin-bottom: 1.5rem;
}

/* ===== CONFIRMATION ===== */
.confirmation-wrapper {
  margin-top: 80px;
  min-height: calc(100vh - 160px);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 3rem 1.5rem;
  background: var(--cream);
}

.confirm-card {
  background: var(--white);
  border: 1px solid var(--border);
  max-width: 560px;
  width: 100%;
  padding: 3rem;
  text-align: center;
}

.confirm-icon {
  width: 56px; height: 56px;
  border-radius: 50%;
  background: var(--forest);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.4rem;
  margin: 0 auto 1.5rem;
}

.confirm-card h1 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 2.2rem;
  font-weight: 300;
  margin-bottom: 0.5rem;
}

.confirm-sub { color: var(--muted); margin-bottom: 2rem; }

.confirm-details {
  text-align: left;
  border: 1px solid var(--border);
  margin-bottom: 1.5rem;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  padding: 0.7rem 1.2rem;
  border-bottom: 1px solid var(--border);
  font-size: 0.9rem;
}
.detail-row:last-child { border-bottom: none; }
.detail-row span { color: var(--muted); }

.confirm-note {
  font-size: 0.85rem;
  color: var(--muted);
  margin-bottom: 2rem;
}

.confirm-actions {
  display: flex;
  gap: 1rem;
  justify-content: center;
  flex-wrap: wrap;
}

/* ===== ADMIN ===== */
.admin-wrapper {
  margin-top: 80px;
  padding: 3rem 2rem 4rem;
  max-width: 1200px;
  margin-left: auto;
  margin-right: auto;
}

.admin-header {
  margin-top: 80px;
  margin-bottom: 2rem;
}

.admin-header h1 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 2.5rem;
  font-weight: 300;
}

.admin-header p { color: var(--muted); }

.admin-table-wrap {
  overflow-x: auto;
}

.admin-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.9rem;
}

.admin-table th {
  font-size: 0.68rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--muted);
  background: var(--cream);
  border: 1px solid var(--border);
  padding: 0.75rem 1rem;
  text-align: left;
}

.admin-table td {
  border: 1px solid var(--border);
  padding: 0.75rem 1rem;
  vertical-align: top;
}

.admin-table tr:hover td { background: #faf8f4; }

.badge {
  font-size: 0.75rem;
  background: var(--dark);
  color: var(--cream);
  padding: 0.15rem 0.5rem;
}

.sub-text { font-size: 0.8rem; color: var(--muted); margin-top: 0.2rem; }

.btn-cancel {
  background: none;
  border: 1.5px solid #c0392b;
  color: #c0392b;
  padding: 0.3rem 0.8rem;
  font-family: 'Jost', sans-serif;
  font-size: 0.75rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  cursor: pointer;
  transition: all 0.2s;
}
.btn-cancel:hover { background: #c0392b; color: white; }

.empty-state {
  text-align: center;
  padding: 4rem;
  color: var(--muted);
}
.empty-state a { color: var(--forest); }

/* ===== FOOTER ===== */
.footer {
  background: var(--dark);
  color: rgba(245,240,232,0.4);
  text-align: center;
  padding: 2rem;
  font-size: 0.8rem;
  letter-spacing: 0.05em;
}
